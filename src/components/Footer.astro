---
const year = new Date().getFullYear();
---

<footer class="bg-dark text-white gold-accent-top">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <div class="md:col-span-2 max-w-sm">
        <img src="/images/logo.svg" alt="JoanieFit — Fitness for Life" class="h-14 w-auto mb-6" />
        <p class="text-white/70 text-[15px] leading-relaxed mb-5">
          Active senior fitness in The Villages, FL. Joanie has been teaching since 1982 —
          helping you move through this phase of life with strength, mobility and durability.
          <span class="text-brand-primary-light font-semibold">Fitness for life.</span>
        </p>
        <div class="flex gap-3">
          <a href="https://www.youtube.com/@VillagesHealthyLiving" target="_blank" rel="noopener" aria-label="YouTube — Villages Healthy Living" class="w-10 h-10 rounded-full bg-white/10 hover:bg-brand-primary flex items-center justify-center transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8zM9.6 15.6V8.4l6.2 3.6-6.2 3.6z"/></svg>
          </a>
          <a href="https://www.instagram.com/joaniefit" target="_blank" rel="noopener" aria-label="Instagram" class="w-10 h-10 rounded-full bg-white/10 hover:bg-brand-primary flex items-center justify-center transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.2c3.2 0 3.6 0 4.9.07 1.2.06 1.8.25 2.2.42.6.2 1 .47 1.4.9.43.4.7.8.9 1.4.17.4.36 1 .42 2.2.07 1.3.07 1.7.07 4.9s0 3.6-.07 4.9c-.06 1.2-.25 1.8-.42 2.2-.2.6-.47 1-.9 1.4-.4.43-.8.7-1.4.9-.4.17-1 .36-2.2.42-1.3.07-1.7.07-4.9.07s-3.6 0-4.9-.07c-1.2-.06-1.8-.25-2.2-.42-.6-.2-1-.47-1.4-.9-.43-.4-.7-.8-.9-1.4-.17-.4-.36-1-.42-2.2C2.2 15.6 2.2 15.2 2.2 12s0-3.6.07-4.9c.06-1.2.25-1.8.42-2.2.2-.6.47-1 .9-1.4.4-.43.8-.7 1.4-.9.4-.17 1-.36 2.2-.42C8.4 2.2 8.8 2.2 12 2.2zm0 3.3a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13zm0 10.7a4.2 4.2 0 1 1 0-8.4 4.2 4.2 0 0 1 0 8.4zm6.8-10.9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-brand-primary-light font-heading text-lg mb-6">Explore</h3>
        <ul class="space-y-3 text-[15px]">
          <li><a href="/classes" class="text-white/70 hover:text-brand-primary-light transition-colors">Classes</a></li>
          <li><a href="/online-classes" class="text-white/70 hover:text-brand-primary-light transition-colors">Online Classes</a></li>
          <li><a href="/gear" class="text-white/70 hover:text-brand-primary-light transition-colors">JoanieFit Gear</a></li>
          <li><a href="/picks-perks" class="text-white/70 hover:text-brand-primary-light transition-colors">Picks &amp; Perks</a></li>
          <li><a href="/story" class="text-white/70 hover:text-brand-primary-light transition-colors">Joanie's Story</a></li>
          <li><a href="/testimonials" class="text-white/70 hover:text-brand-primary-light transition-colors">Reviews</a></li>
          <li><a href="/faq" class="text-white/70 hover:text-brand-primary-light transition-colors">FAQ</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-brand-primary-light font-heading text-lg mb-6">Get in Touch</h3>
        <ul class="space-y-4 text-[15px]">
          <li><a href="mailto:Joanie@JoanieFit.com" class="text-white/70 hover:text-brand-primary-light transition-colors">Joanie@JoanieFit.com</a></li>
          <li class="text-white/70">The Villages, FL</li>
          <li class="text-white/70">Email is the best way to reach Joanie</li>
        </ul>
        <div class="mt-6 pt-4 border-t border-white/10">
          <p class="text-xs text-white/50">Licensed &amp; insured. Classes held at The Villages recreation centers.</p>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-3 text-center">
      <p class="text-xs text-white/50">&copy; {year} JoanieFit, LLC. All rights reserved.</p>
      <p class="text-xs text-white/40">Fitness for life · The Villages, Florida</p>
    </div>
  </div>
</footer>
