---
interface Props {
  title: string;
  subtitle: string;
  image?: string;        // kept for compatibility; heroes are now photo-free
  compact?: boolean;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  badges?: string[];
}

const { title, subtitle, compact = false, primaryCta, secondaryCta, badges } = Astro.props;
---

<section class:list={["relative overflow-hidden hero-grain hero-brand", compact ? "py-14 md:py-20" : "py-16 md:py-24 lg:py-28"]}>
  <!-- Branded gradient + decorative motif (no photo) -->
  <div class="absolute inset-0 hero-brand-bg"></div>
  <div class="absolute -top-24 -right-16 w-[36rem] h-[36rem] rounded-full bg-brand-primary-light/20 blur-3xl pointer-events-none"></div>
  <div class="absolute -bottom-32 -left-24 w-[34rem] h-[34rem] rounded-full bg-brand-secondary/15 blur-3xl pointer-events-none"></div>
  <svg class="absolute bottom-0 left-0 w-full h-40 opacity-[0.12] pointer-events-none" viewBox="0 0 1200 160" preserveAspectRatio="none" fill="none" aria-hidden="true">
    <path d="M0 120 H360 L400 60 L460 140 L520 20 L580 120 H1200" stroke="#ffffff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class:list={[compact ? "max-w-3xl mx-auto text-center" : "max-w-3xl"]}>
      <h1 class:list={["font-heading leading-tight", compact ? "text-3xl md:text-5xl" : "text-4xl md:text-5xl lg:text-6xl"]} style="color: #fff;">
        {title}
      </h1>
      <p class:list={["text-white/80 mt-5 leading-relaxed", compact ? "text-base md:text-lg" : "text-lg md:text-xl max-w-2xl"]}>
        {subtitle}
      </p>

      {badges && badges.length > 0 && (
        <div class:list={["flex flex-wrap gap-3 mt-6", compact && "justify-center"]}>
          {badges.map(badge => (
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold tracking-wide bg-white/10 text-white/90 border border-white/15 backdrop-blur-sm">
              <span class="w-1.5 h-1.5 rounded-full bg-brand-primary-light"></span>
              {badge}
            </span>
          ))}
        </div>
      )}

      {(primaryCta || secondaryCta) && (
        <div class:list={["mt-9 flex flex-col sm:flex-row gap-4", compact ? "items-center justify-center" : "items-start"]}>
          {primaryCta && (
            <a href={primaryCta.href} class="btn-lift inline-flex items-center px-8 py-4 bg-white text-brand-primary-dark hover:bg-white/90 text-sm font-bold uppercase tracking-wider rounded-full">
              {primaryCta.label}
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          )}
          {secondaryCta && (
            <a href={secondaryCta.href} class="btn-lift inline-flex items-center px-8 py-4 border-2 border-white/40 hover:border-white hover:bg-white/10 text-white text-sm font-bold uppercase tracking-wider rounded-full backdrop-blur-sm">
              {secondaryCta.label}
            </a>
          )}
        </div>
      )}
    </div>
  </div>
</section>
