---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatBar from '../components/StatBar.astro';
import ServiceCard from '../components/ServiceCard.astro';

const YOUTUBE = 'https://www.youtube.com/@VillagesHealthyLiving';

const heroBadges = ['The Villages, FL', 'Active senior fitness', 'All levels welcome'];

const classes = [
  {
    title: 'Low Impact Kickboxing',
    description: 'All the energy and fun of kickboxing — combinations, cardio and core — with joint-friendly movement designed for active bodies.',
    icon: '<svg class="w-6 h-6 text-brand-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>',
  },
  {
    title: 'Bodysculpt',
    description: 'Full-body strength using light weights and resistance to build the lean, capable muscle that keeps you strong and independent.',
    icon: '<svg class="w-6 h-6 text-brand-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 6v12M18 6v12M3 9h3M18 9h3M6 12h12"/></svg>',
  },
  {
    title: 'Coresculpt',
    description: 'Targeted core and stability work that protects your back, sharpens your balance and powers everything you do.',
    icon: '<svg class="w-6 h-6 text-brand-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v18M3 12h18"/></svg>',
  },
  {
    title: 'Free Class at Sawgrass',
    description: 'Joanie\'s Wednesday class at Sawgrass is free to everyone, every week — no commitment, just bring water and a smile.',
    icon: '<svg class="w-6 h-6 text-brand-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>',
  },
];

const reasons = [
  { title: 'Teaching since 1982', text: 'Four decades of real coaching experience. Joanie has guided thousands of bodies safely and effectively.' },
  { title: 'Built for active seniors', text: 'Every class is designed to build strength, mobility and durability for this stage of life — never one-size-fits-all.' },
  { title: 'Energy that’s contagious', text: 'Students describe Joanie’s classes as the highlight of their week. You’ll work hard and leave smiling.' },
  { title: 'Right here in The Villages', text: 'Classes meet at recreation centers around The Villages — convenient, friendly and close to home.' },
];

const testimonials = [
  { quote: 'Joanie’s infectious energy makes every class fly by. I leave feeling stronger and happier every single time.', name: 'Amy', role: 'Class member' },
  { quote: 'Her classes are my vital stress release. I’ve never stuck with a fitness routine like this before.', name: 'Kathryn', role: 'Member' },
  { quote: 'The challenging combinations keep me motivated. Joanie meets you where you are and pushes you further.', name: 'Taryn', role: 'Longtime student' },
];
---

<BaseLayout title="Active Senior Fitness in The Villages, FL">
  <!-- Branded hero (photo-free) -->
  <section class="relative overflow-hidden hero-grain py-14 md:py-20 lg:py-24">
    <div class="absolute inset-0 hero-brand-bg"></div>
    <div class="absolute -top-24 -right-16 w-[42rem] h-[42rem] rounded-full bg-brand-primary-light/20 blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-40 -left-24 w-[40rem] h-[40rem] rounded-full bg-brand-secondary/15 blur-3xl pointer-events-none"></div>
    <svg class="absolute bottom-0 left-0 w-full h-48 opacity-[0.12] pointer-events-none" viewBox="0 0 1200 160" preserveAspectRatio="none" fill="none" aria-hidden="true">
      <path d="M0 120 H340 L380 50 L440 145 L500 15 L560 120 H1200" stroke="#ffffff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2 text-brand-primary-light font-bold uppercase tracking-[0.25em] text-sm mb-5">
          <span class="w-8 h-px bg-brand-primary-light"></span>Fitness for life
        </span>
        <h1 class="font-heading leading-tight text-4xl md:text-5xl lg:text-6xl" style="color:#fff;">
          Strength, mobility &amp; durability — for this phase of life.
        </h1>
        <p class="text-white/80 mt-5 leading-relaxed text-lg md:text-xl max-w-2xl">
          Joanie has been teaching fitness since 1982. Join her low-impact classes in The Villages
          and discover just how much your body is still capable of.
        </p>

        <div class="flex flex-wrap gap-3 mt-6">
          {heroBadges.map(badge => (
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold tracking-wide bg-white/10 text-white/90 border border-white/15 backdrop-blur-sm">
              <span class="w-1.5 h-1.5 rounded-full bg-brand-primary-light"></span>
              {badge}
            </span>
          ))}
        </div>

        <div class="mt-9 flex flex-col sm:flex-row gap-4 items-start">
          <a href="/free-class" class="btn-lift inline-flex items-center px-8 py-4 bg-white text-brand-primary-dark hover:bg-white/90 text-sm font-bold uppercase tracking-wider rounded-full">
            Take a Free Class
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href={YOUTUBE} target="_blank" rel="noopener" class="btn-lift inline-flex items-center px-8 py-4 border-2 border-white/40 hover:border-white hover:bg-white/10 text-white text-sm font-bold uppercase tracking-wider rounded-full backdrop-blur-sm">
            Work Out Online
          </a>
        </div>
      </div>
    </div>
  </section>

  <StatBar />

  <!-- Intro -->
  <section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid lg:grid-cols-2 gap-14 items-center">
      <div class="fade-in-up">
        <span class="text-brand-primary font-bold uppercase tracking-[0.2em] text-sm">Meet Joanie</span>
        <h2 class="text-3xl md:text-4xl text-dark mt-3 mb-6">Fitness for life — guided by someone who's done it for 40+ years</h2>
        <p class="text-lg text-dark-light/85 leading-relaxed mb-5">
          Joanie's knowledge of fitness and her genuine passion shine through in every class. She
          helps you realize how much your body is capable of and guides you through this phase of
          life with confidence and care.
        </p>
        <p class="text-lg text-dark-light/85 leading-relaxed mb-8">
          No intimidation, no pressure — just smart, joyful movement alongside neighbors who
          become friends. Classes are kept small, so you're never lost in the crowd.
        </p>
        <a href="/story" class="btn-lift inline-flex items-center px-8 py-4 bg-brand-primary hover:bg-brand-primary-dark text-white text-sm font-bold uppercase tracking-wider rounded-full">
          Read Joanie's Story
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
      <div class="fade-in-up">
        <div class="relative rounded-2xl overflow-hidden shadow-xl">
          <img src="/images/jf-photo-4.jpg" alt="Joanie leading an energetic group fitness class" class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- Classes -->
  <section class="py-20 md:py-28 bg-light-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14 fade-in-up">
        <span class="text-brand-primary font-bold uppercase tracking-[0.2em] text-sm">The Classes</span>
        <h2 class="text-3xl md:text-4xl text-dark mt-3 mb-4">Move strong, feel capable</h2>
        <p class="text-lg text-dark-light/80">Four ways to train with Joanie in The Villages — start with a free class anytime.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {classes.map(c => (
          <div class="fade-in-up"><ServiceCard title={c.title} description={c.description} icon={c.icon} /></div>
        ))}
      </div>
      <div class="text-center mt-12 fade-in-up">
        <a href="/classes" class="btn-lift inline-flex items-center px-8 py-4 bg-brand-primary hover:bg-brand-primary-dark text-white text-sm font-bold uppercase tracking-wider rounded-full">
          See All Classes &amp; Schedule
        </a>
      </div>
    </div>
  </section>

  <!-- Why JoanieFit -->
  <section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14 fade-in-up">
        <span class="text-brand-primary font-bold uppercase tracking-[0.2em] text-sm">Why JoanieFit</span>
        <h2 class="text-3xl md:text-4xl text-dark mt-3">What makes the difference</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {reasons.map(r => (
          <div class="fade-in-up card-accent bg-white rounded-lg border border-gray-100 p-7">
            <div class="w-11 h-11 rounded-full bg-brand-primary/10 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-brand-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </div>
            <h3 class="text-lg text-dark mb-2">{r.title}</h3>
            <p class="text-[15px] text-dark-light/80 leading-relaxed">{r.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-20 md:py-28 bg-dark text-white relative overflow-hidden hero-grain">
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14 fade-in-up">
        <span class="text-brand-primary-light font-bold uppercase tracking-[0.2em] text-sm">Loved by students</span>
        <h2 class="text-3xl md:text-4xl text-white mt-3">Why they keep coming back</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-7">
        {testimonials.map(t => (
          <div class="fade-in-up bg-white/5 border border-white/10 rounded-2xl p-8 backdrop-blur-sm">
            <svg class="w-9 h-9 text-brand-primary-light mb-4" fill="currentColor" viewBox="0 0 24 24"><path d="M9.6 8C6.5 8 4 10.5 4 13.6V20h6.4v-6.4H7.2c0-1.8 1.4-3.2 3.2-3.2V8H9.6zm9.6 0c-3.1 0-5.6 2.5-5.6 5.6V20H20v-6.4h-3.2c0-1.8 1.4-3.2 3.2-3.2V8h-.8z"/></svg>
            <p class="text-lg leading-relaxed text-white/90 mb-6">{t.quote}</p>
            <div class="font-bold text-brand-primary-light">{t.name}</div>
            <div class="text-sm text-white/50">{t.role}</div>
          </div>
        ))}
      </div>
      <div class="text-center mt-12 fade-in-up">
        <a href="/testimonials" class="btn-lift inline-flex items-center px-8 py-4 bg-brand-primary hover:bg-brand-primary-dark text-white text-sm font-bold uppercase tracking-wider rounded-full">
          Read More Reviews
        </a>
      </div>
    </div>
  </section>

  <!-- Online / YouTube teaser -->
  <section class="py-20 md:py-28 bg-light-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid lg:grid-cols-2 gap-14 items-center">
      <div class="fade-in-up order-2 lg:order-1">
        <a href={YOUTUBE} target="_blank" rel="noopener" class="group block relative rounded-2xl overflow-hidden shadow-xl aspect-video bg-dark" aria-label="Open Joanie's YouTube channel">
          <img src="/images/joanie-leading.jpg" alt="Joanie leading a class" class="w-full h-full object-cover opacity-80 group-hover:opacity-95 transition-opacity" />
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="w-20 h-20 rounded-full bg-brand-secondary group-hover:scale-110 transition-transform flex items-center justify-center shadow-lg">
              <svg class="w-8 h-8 text-white ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </span>
          </div>
        </a>
      </div>
      <div class="fade-in-up order-1 lg:order-2">
        <span class="text-brand-primary font-bold uppercase tracking-[0.2em] text-sm">Can't make it in person?</span>
        <h2 class="text-3xl md:text-4xl text-dark mt-3 mb-6">Work out with Joanie online</h2>
        <p class="text-lg text-dark-light/85 leading-relaxed mb-8">
          Joanie's <strong>Villages Healthy Living</strong> channel brings her classes to your living
          room. Your first class is free — then join through membership to unlock the full library
          and follow along anytime, at your own pace.
        </p>
        <a href={YOUTUBE} target="_blank" rel="noopener" class="btn-lift inline-flex items-center px-8 py-4 bg-brand-primary hover:bg-brand-primary-dark text-white text-sm font-bold uppercase tracking-wider rounded-full">
          Work Out Online
        </a>
      </div>
    </div>
  </section>

  <!-- CTA strip -->
  <section class="relative overflow-hidden hero-grain py-20">
    <div class="absolute inset-0 hero-brand-bg"></div>
    <div class="absolute -top-24 -right-20 w-[36rem] h-[36rem] rounded-full bg-brand-primary-light/15 blur-3xl pointer-events-none"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl text-white mb-5">Your first class is on us — every week</h2>
      <p class="text-lg text-white/85 mb-9">Joanie's Wednesday class at Sawgrass is free to everyone. Come see why students have trained with her for years.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/free-class" class="btn-lift inline-flex items-center justify-center px-8 py-4 bg-white text-brand-primary-dark hover:bg-white/90 text-sm font-bold uppercase tracking-wider rounded-full">Take a Free Class</a>
        <a href="/classes" class="btn-lift inline-flex items-center justify-center px-8 py-4 border-2 border-white/40 hover:border-white hover:bg-white/10 text-white text-sm font-bold uppercase tracking-wider rounded-full backdrop-blur-sm">See All Classes</a>
      </div>
    </div>
  </section>
</BaseLayout>
